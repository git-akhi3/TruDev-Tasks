# Database

# Async SQLAlchemy connection string used by the API and worker.
DATABASE_URL=postgresql+asyncpg://pulsepay:pulsepay@localhost:5432/pulsepay

# Number of persistent DB connections kept in the pool.
DB_POOL_SIZE=10

# Number of extra overflow DB connections allowed beyond the base pool.
DB_MAX_OVERFLOW=20

# Seconds to wait before timing out when acquiring a DB connection.
DB_POOL_TIMEOUT_SECONDS=30

# Seconds after which pooled DB connections are recycled.
DB_POOL_RECYCLE_SECONDS=1800

# Security

# Secret key used for signing and security-sensitive application operations.
SECRET_KEY=replace-with-a-long-random-secret

# Secret used to sign outbound webhook payloads.
WEBHOOK_SIGNING_SECRET=replace-with-webhook-signing-secret

# Application

# Deployment environment that controls behavior like docs exposure and startup migration policy.
ENVIRONMENT=development

# Enables startup seed data for development environments.
SEED_ON_STARTUP=false

# Rate Limiting

# Sustained request budget per API key measured in requests per minute.
API_RATE_LIMIT_PER_MINUTE=100

# Short-burst request budget per API key measured in requests per second.
API_BURST_LIMIT_PER_SECOND=20

# Jobs

# Maximum attempts allowed before a payment retry flow is marked terminal.
MAX_PAYMENT_RETRY_ATTEMPTS=3

# Observability

# No dedicated observability environment variable is currently required.
# (Request IDs and structured logs are enabled by default.)
